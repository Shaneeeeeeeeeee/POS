# Copy to .env.local and fill in. Never commit .env.local.
#
# API: Dashboard → Project Settings → API
# DB:  Dashboard → Project Settings → Database → URI (use pooler / transaction mode if offered)
# Auth: Authentication → URL configuration → Site URL: http://localhost:3000 (for local dev)

# --- Next.js + Supabase JS ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use anon OR publishable (app prefers anon if both are set; see src/lib/supabase/env.ts)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only: used by privileged server actions (team/admin flows)
SUPABASE_SERVICE_ROLE_KEY=

# Team password reset default (admin-only reset action). MUST be changed in production.
DEFAULT_TEAM_PASSWORD=

# Optional: used by scripts/tools that connect directly to Postgres
# Replace [PASSWORD] with your DB password; URL-encode special chars (! → %21)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
